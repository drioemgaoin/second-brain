# Copy this file to `.env` and adjust if needed.
# For the default setup you do not have to change anything — Ollama runs
# unauthenticated on localhost and GBrain finds it automatically.

# Where Ollama listens. Default already matches docker-compose.yml.
# OLLAMA_BASE_URL=http://localhost:11434/v1

# The free local embedding model pulled by `make pull-model`.
EMBEDDING_MODEL=ollama:nomic-embed-text

# --- Only for the "full Docker" Postgres upgrade ---
# POSTGRES_URL=postgresql://gbrain:gbrain@localhost:5432/gbrain
