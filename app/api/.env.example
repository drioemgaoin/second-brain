# Required — GBrain HTTP MCP server URL
GBRAIN_URL=http://localhost:3002

# Port for the API server (default: 3001)
# PORT=3001

# CORS origin — the chat frontend URL (default: any localhost)
# CORS_ORIGIN=https://yourdomain.com

# Ollama chat model (default: llama3.2)
# Pull it first: docker exec second-brain-ollama ollama pull llama3.2
# CHAT_MODEL=llama3.2

# Ollama API URL (default: http://localhost:11434/v1)
# OLLAMA_BASE_URL=http://localhost:11434/v1
