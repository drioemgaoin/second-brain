# Production environment — copy to .env at the project root
# cp deploy/.env.example .env

# API address: use your VPS IP for plain HTTP, or a domain for auto-HTTPS
# Examples:
#   API_DOMAIN=123.45.67.89      → http://123.45.67.89
#   API_DOMAIN=api.yourdomain.com → https://api.yourdomain.com (auto-TLS)
API_DOMAIN=api.yourdomain.com

# Chat frontend URL (for CORS — your Cloudflare Pages domain)
# Comma-separated for multiple origins
CORS_ORIGIN=https://your-project.pages.dev

# Ollama models (auto-pulled on first deploy)
CHAT_MODEL=llama3.2
EMBEDDING_MODEL=nomic-embed-text

# --- Cloudflare Named Tunnel ---
# Stable HTTPS URL for the API (no domain needed).
# See deploy/README-tunnel.md for setup instructions.
# CLOUDFLARE_TUNNEL_ID=your-tunnel-id
